# 邮件配置
email:
  sender: "your_qq_email@qq.com"      # 发件人QQ邮箱
  password: "your_auth_code"           # QQ邮箱授权码
  recipient: "partner@example.com"     # 收件人邮箱
  smtp_server: "smtp.qq.com"
  smtp_port: 465
  sender_name: "亲爱的"                # 发件人显示称呼
  recipient_name: "宝贝"               # 收件人显示称呼

# 恋爱信息
love:
  start_date: "2023-01-01"             # 恋爱起始日期 YYYY-MM-DD

# 纪念日列表
anniversaries:
  - name: "恋爱纪念日"
    date: "01-01"                      # MM-DD格式
  - name: "TA的生日"
    date: "12-25"

# 天气配置
weather:
  city: "Beijing"                      # 城市名称（英文）
  api_key: "your_openweathermap_api_key"

# 其他配置
app:
  timezone: "Asia/Shanghai"
  template: "romantic"                 # 模板名称: romantic

  # 图标配置 - 支持两种方式：
  # 方式1: 使用本地图片（自动转base64）
  # icon_url: "romantic-icon"          # 使用 assets/images/romantic-icon.png
  #
  # 方式2: 使用外部URL（推荐，避免邮件过大）
  # icon_url: "https://your-cdn.com/icon.png"
  icon_url: "romantic-icon"

  # 背景配置 - 支持两种方式：
  # 方式1: 渐变色
  background_type: "gradient"          # gradient 或 image
  background_image: "romantic"         # gradient时使用 romantic/nature/city
  #
  # 方式2: 图片背景（使用外部URL）
  # background_type: "image"
  # background_image: "https://your-cdn.com/bg.png"
